# Slatebase Backend Environment Variables
# Copy this file to .env and adjust values as needed.
# Environment variables take precedence over config/default.json values.
# The server is started with: node --env-file=.env src/index.ts

# Server port (default: 3000)
SLATEBASE_PORT=3000

# Host address (default: 127.0.0.1)
SLATEBASE_HOST=127.0.0.1

# Log level: debug | info | warn | error (default: info)
SLATEBASE_LOG_LEVEL=info

# Comma-separated vault paths (overrides config file vaults)
SLATEBASE_VAULT_PATHS=/path/to/vault1,/path/to/vault2

# Maximum file size in bytes (default: 5242880 = 5 MB)
SLATEBASE_MAX_FILE_SIZE=5242880

# Comma-separated allowed origins for CORS (default: http://localhost:5173)
SLATEBASE_ALLOWED_ORIGINS=http://localhost:5173

# CSRF secret for session tokens (min 32 chars, random generated if not set)
# SLATEBASE_CSRF_SECRET=your-csrf-secret-here-at-least-32-characters

# Sync encryption secret for credential storage (min 32 chars, random generated if not set)
# WARNING: If not set, encrypted sync credentials will not survive server restarts.
# SLATEBASE_SYNC_SECRET=your-sync-secret-here-at-least-32-characters

# MCP Context Server
# Enable or disable the MCP server (default: true)
SLATEBASE_MCP_ENABLED=true

# Maximum file size in bytes for MCP reads (default: 5242880 = 5 MB)
SLATEBASE_MCP_MAX_FILE_SIZE=5242880

# Maximum MCP requests per minute per token (default: 60)
SLATEBASE_MCP_RATE_LIMIT=60
