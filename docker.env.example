# Slatebase Docker Environment Configuration
# Copy this file to docker.env and adjust values for your deployment.

# --- Backend Server ---
SLATEBASE_PORT=3000
SLATEBASE_HOST=0.0.0.0
SLATEBASE_LOG_LEVEL=info

# --- CORS ---
# Set to your actual domain in production (e.g. https://slatebase.example.com)
SLATEBASE_ALLOWED_ORIGINS=http://localhost:8080

# --- Reverse Proxy ---
# Trusted proxy IPs or CIDR ranges (comma-separated).
# Only connections from these addresses will have X-Forwarded-For evaluated.
# Set to the Docker network subnet of your reverse proxy (e.g. Nginx Proxy Manager).
# Find it with: docker network inspect <network-name> --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
# Examples: 172.19.0.0/16, 127.0.0.1, * (trust all — not recommended)
# Leave empty if not behind a reverse proxy.
# SLATEBASE_TRUSTED_PROXIES=172.19.0.0/16

# --- CSRF Secret ---
# IMPORTANT: Generate a persistent secret for production!
# Run: openssl rand -hex 32
# If not set, a random secret is generated on each restart (invalidates all sessions).
SLATEBASE_CSRF_SECRET=

# --- Sync Encryption Secret ---
# Encrypts stored CouchDB/LiveSync credentials (AES-256-GCM). Min 32 characters.
# Run: openssl rand -hex 32
# If not set, a random secret is generated on each restart (sync credentials become unreadable).
# Only needed if you use CouchDB vault synchronization.
# SLATEBASE_SYNC_SECRET=

# --- Vault Configuration ---
# Leave empty to use only vaults created via the UI.
# SLATEBASE_VAULT_PATHS=

# --- File Limits ---
SLATEBASE_MAX_FILE_SIZE=5242880

# --- External Port (used by docker-compose) ---
SLATEBASE_EXTERNAL_PORT=8080
