# Slatebase Docker Environment Configuration
# Copy this file to docker.env and adjust values for your deployment.

# --- Backend Server ---
SLATEBASE_PORT=3000
SLATEBASE_HOST=0.0.0.0
SLATEBASE_LOG_LEVEL=info

# --- CORS ---
# Set to your actual domain in production (e.g. https://slatebase.example.com)
SLATEBASE_ALLOWED_ORIGINS=http://localhost:8080

# --- CSRF Secret ---
# IMPORTANT: Generate a persistent secret for production!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, a random secret is generated on each restart (invalidates all sessions).
SLATEBASE_CSRF_SECRET=

# --- Vault Configuration ---
# Leave empty to use only vaults created via the UI.
# SLATEBASE_VAULT_PATHS=

# --- File Limits ---
SLATEBASE_MAX_FILE_SIZE=5242880

# --- External Port (used by docker-compose) ---
SLATEBASE_EXTERNAL_PORT=8080
